# 环境变量配置文件
# 复制此文件为 .env 并填写实际值

# 应用配置
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ==================== AI模型配置 ====================
# 默认AI提供商: qwen
AI_PROVIDER=qwen

# 默认模型名称
AI_DEFAULT_MODEL=qwen3.5-plus

# AI温度参数 (0-2)
AI_TEMPERATURE=0.7

# AI最大输出token数
AI_MAX_TOKENS=2048

# 通义千问API配置
# 支持模型: qwen3.5-plus, kimi-k2.5, MiniMax-M2.5, qwen3-max-2026-01-23
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可用模型列表(逗号分隔)
AI_AVAILABLE_MODELS=qwen3.5-plus,kimi-k2.5,MiniMax-M2.5,qwen3-max-2026-01-23

# Ollama配置(本地模型)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:14b

# 文心一言API配置
ERNIE_API_KEY=
ERNIE_SECRET_KEY=

# 智谱GLM API配置
ZHIPU_API_KEY=

# ==================== 数据库配置 ====================
DATABASE_PATH=data/db/audit.db

# ==================== 文件存储配置 ====================
ATTACHMENT_PATH=data/attachments
OCR_CACHE_PATH=data/ocr
PAPER_PATH=data/papers

# ==================== JWT配置 ====================
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440