# ===========================================================
# AI审计抽凭助手 - 环境变量配置模板
# ===========================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. 所有标记为 [必填] 的配置项必须设置
# 4. API Key 等敏感信息不应提交到版本控制
# ===========================================================

# ==================== 应用配置 ====================
# 调试模式: 生产环境设为 false
DEBUG=false

# [必填] JWT签名密钥
# 生产环境必须设置强密钥（至少32字符的随机字符串）
# 生成方法: openssl rand -hex 32
SECRET_KEY=your-secret-key-at-least-32-characters-long

# ==================== AI模型配置 ====================
# 默认AI提供商: qwen / ollama / ernie / zhipu
AI_PROVIDER=qwen

# 默认模型名称
AI_DEFAULT_MODEL=qwen3.5-plus

# AI温度参数 (0-2)，越高越随机
AI_TEMPERATURE=0.7

# AI最大输出token数
AI_MAX_TOKENS=2048

# 可用模型列表(逗号分隔)
AI_AVAILABLE_MODELS=qwen3.5-plus,qwen3.5-plus-2026-02-15,kimi-k2.5,MiniMax-M2.5,qwen3-max-2026-01-23

# ==================== AI供应商配置 ====================

# ----- 通义千问 (阿里云) -----
# [推荐] 性价比高，中文能力强
# 获取地址: https://dashscope.console.aliyun.com/
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ----- Ollama (本地部署) -----
# 无需API Key，适合隐私敏感场景
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:14b

# ----- 文心一言 (百度) -----
# 获取地址: https://console.bce.baidu.com/qianfan/
ERNIE_API_KEY=
ERNIE_SECRET_KEY=

# ----- 智谱GLM -----
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ==================== AI场景化配置 ====================
# 说明: 可为不同用途配置不同的模型和API Key
# 优先级: 场景配置 > 供应商配置 > 默认配置

# ----- 图片/PDF识别专用 -----
# 推荐使用视觉模型: qwen-vl-max, qwen3.5-omni-plus, glm-4v
AI_RECOGNITION_PROVIDER=qwen
AI_RECOGNITION_MODEL=qwen3.5-omni-plus
AI_RECOGNITION_API_KEY=
AI_RECOGNITION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_RECOGNITION_TEMPERATURE=0.3

# ----- 风险分析专用 -----
# 推荐使用推理能力强的模型
AI_RISK_ANALYSIS_PROVIDER=qwen
AI_RISK_ANALYSIS_MODEL=qwen3.5-plus-2026-02-15
AI_RISK_ANALYSIS_API_KEY=
AI_RISK_ANALYSIS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_RISK_ANALYSIS_TEMPERATURE=0.3

# ----- 通用AI服务专用 -----
AI_GENERAL_PROVIDER=qwen
AI_GENERAL_MODEL=qwen3.5-plus
AI_GENERAL_API_KEY=
AI_GENERAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GENERAL_TEMPERATURE=0.7

# ----- 模型分类列表 -----
AI_GENERAL_MODELS=qwen3.5-plus,qwen3.5-plus-2026-02-15,qwen3.5-flash
AI_VISION_MODELS=qwen3.5-omni-plus,qwen-vl-max,glm-4v
AI_RISK_MODELS=qwen3.5-plus,qwen3-max,kimi-k2.5,glm-4-flash

# ==================== OCR配置 ====================
OCR_PROVIDER=paddleocr
OCR_LANGUAGE=ch

# ==================== 数据库配置 ====================
DATABASE_PATH=data/db/audit.db

# ==================== 文件存储配置 ====================
ATTACHMENT_PATH=data/attachments
OCR_CACHE_PATH=data/ocr
PAPER_PATH=data/papers

# ==================== JWT配置 ====================
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ==================== 文件上传配置 ====================
MAX_UPLOAD_SIZE=52428800

# ==================== CORS配置 ====================
# 生产环境应配置实际的域名
# 多个域名用逗号分隔，或通过环境变量 CORS_ORIGINS 设置
# CORS_ORIGINS=http://localhost:5173,https://your-domain.com
